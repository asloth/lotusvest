rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Colección pitch_project - proyectos de pitch
    match /pitch_project/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Otras colecciones - restricción por defecto
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 4, 7);
    }
  }
}
